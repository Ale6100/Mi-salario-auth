{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "node --run dev",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "frontend-group"
      }
    },
    {
      "label": "Start Ngrok",
      "type": "shell",
      "command": "ngrok http 5173",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "frontend-group"
      }
    },
    {
      "label": "Start All",
      "dependsOn": [
        "Start Frontend",
        "Start Ngrok"
      ],
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
